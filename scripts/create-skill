#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

usage() {
  cat <<'EOF_USAGE'
Usage:
  ./scripts/create-skill <skill-id> <display-name> <summary> [--style yes|no] [--platforms codex,claude,cursor]

Example:
  ./scripts/create-skill api-error-triage "API Error Triage" "Diagnose recurring backend API failures." --style no
EOF_USAGE
}

if [ $# -lt 3 ]; then
  usage >&2
  exit 1
fi

skill="$1"
name="$2"
summary="$3"
shift 3
style="no"
platforms="codex,claude,cursor"

while [ $# -gt 0 ]; do
  case "$1" in
    --style)
      style="$2"
      shift 2
      ;;
    --platforms)
      platforms="$2"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ "$style" != "yes" ] && [ "$style" != "no" ]; then
  echo "--style must be yes or no" >&2
  exit 1
fi

DIR="$(skill_dir "$ROOT" "$skill")"
if [ -e "$DIR" ]; then
  echo "Skill already exists: $skill" >&2
  exit 1
fi

"$ROOT/scripts/init-skill" "$skill" "$name" >/dev/null

export SKILLS_REPO_ROOT="$ROOT"
export SKILL_ID="$skill"
export SKILL_NAME="$name"
export SKILL_SUMMARY="$summary"
export SKILL_STYLE="$style"
export SKILL_PLATFORMS="$platforms"

python3 - <<'PY'
from pathlib import Path
import os
import textwrap

root = Path(os.environ['SKILLS_REPO_ROOT'])
skill = os.environ['SKILL_ID']
name = os.environ['SKILL_NAME']
summary = os.environ['SKILL_SUMMARY']
style = os.environ['SKILL_STYLE']
platforms = [p.strip() for p in os.environ['SKILL_PLATFORMS'].split(',') if p.strip()]
dir = root / 'skills' / skill
skill_yaml = dir / 'skill.yaml'
text = skill_yaml.read_text()
text = text.replace('summary: TODO summary', f'summary: {summary}')
for platform in ['codex', 'claude', 'cursor']:
    enabled = 'true' if platform in platforms else 'false'
    text = text.replace(f'  {platform}: true', f'  {platform}: {enabled}')
skill_yaml.write_text(text)

files = {
    'intent.md': f'''# Intent\n\n## Summary\n\n{summary}\n\n## Use it for\n\n- TODO primary use case\n- TODO secondary use case\n- TODO target teammate or persona\n\n## Default assumptions\n\n- TODO assumption 1\n- TODO assumption 2\n- TODO assumption 3\n\n## Typical outputs\n\n- TODO output 1\n- TODO output 2\n- TODO output 3\n''',
    'workflow.md': '''# Workflow\n\n## Standard flow\n\n1. TODO intake step\n2. TODO decision step\n3. TODO execution step\n4. TODO output step\n\n## Decision points\n\n- TODO decision rule 1\n- TODO decision rule 2\n\n## Output contract\n\n1. TODO output order 1\n2. TODO output order 2\n3. TODO output order 3\n''',
    'prompts.md': '''# Prompt Templates\n\n## Template 1: Basic request\n\n```text\n请帮我使用这个 skill：\n目标: [一句话]\n输入: [用户会提供什么]\n输出: [期望产出什么]\n约束: [边界或限制]\n```\n\n## Template 2: Rough draft normalization\n\n```text\n下面是一份 rough draft，请按这个 skill 的工作流整理输出：\n[粘贴内容]\n```\n''',
    'patterns.md': '''# Patterns\n\n## Classification\n\n- TODO classify common request types\n- TODO define reusable structures\n\n## Reusable patterns\n\n- TODO pattern 1\n- TODO pattern 2\n- TODO pattern 3\n''',
    'style.md': '''# Style\n\nThis skill does not rely on visual style rules. Keep `style.md` minimal unless the skill later proves to need visual intake or style presets.\n''' if style == 'no' else '''# Style\n\n## Visual intake\n\n- TODO plain-language style inputs\n- TODO reference product mapping\n- TODO image-to-style rules\n\n## Presets\n\n- TODO preset 1\n- TODO preset 2\n''',
    'validation.md': '''# Validation\n\n## Minimum checklist\n\n- TODO source files are complete\n- TODO workflow is reusable\n- TODO prompts are usable by another teammate\n\n## Validation scenarios\n\n- ideal input scenario\n- vague input scenario\n- failure or edge-case scenario\n\n## Pass conditions\n\n- TODO pass condition 1\n- TODO pass condition 2\n''',
    'install-notes.md': '''# Install Notes\n\n## Repository policy\n\n- edit `core/` and `skill.yaml`\n- do not treat generated adapters as source of truth\n- run `./scripts/build <skill-id>` after edits\n\n## Platform notes\n\n- Codex adapter is generated under `adapters/codex/`\n- Claude adapter is generated under `adapters/claude/`\n- Cursor adapter is generated under `adapters/cursor/`\n''',
}
for filename, content in files.items():
    (dir / 'core' / filename).write_text(textwrap.dedent(content))

catalog = root / 'catalog.yaml'
entry = textwrap.dedent(f'''\
  - id: {skill}\n    name: {name}\n    version: 0.1.0\n    summary: {summary}\n    platforms:\n      codex: {'true' if 'codex' in platforms else 'false'}\n      claude: {'true' if 'claude' in platforms else 'false'}\n      cursor: {'true' if 'cursor' in platforms else 'false'}\n''')
existing = catalog.read_text()
if f'id: {skill}' not in existing:
    catalog.write_text(existing.rstrip() + '\n' + entry)
PY

"$ROOT/scripts/build" "$skill" >/dev/null
"$ROOT/scripts/doctor" "$skill"

echo "created $skill"
echo "Next step: use cross-tool-skill-creator to replace the starter TODO blocks with real reusable source content."
