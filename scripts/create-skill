#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

usage() {
  cat <<'EOF_USAGE'
用法:
  ./scripts/create-skill <skill-id> <display-name> <summary> [--style yes|no] [--platforms codex,claude,cursor]

示例:
  ./scripts/create-skill api-error-triage "API 异常排查" "用于诊断重复出现的后端 API 故障。" --style no
EOF_USAGE
}

if [ $# -lt 3 ]; then
  usage >&2
  exit 1
fi

skill="$1"
name="$2"
summary="$3"
shift 3
style="no"
platforms="codex,claude,cursor"

while [ $# -gt 0 ]; do
  case "$1" in
    --style)
      style="$2"
      shift 2
      ;;
    --platforms)
      platforms="$2"
      shift 2
      ;;
    *)
      echo "未知参数: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ "$style" != "yes" ] && [ "$style" != "no" ]; then
  echo "--style 只能是 yes 或 no" >&2
  exit 1
fi

DIR="$(skill_dir "$ROOT" "$skill")"
if [ -e "$DIR" ]; then
  echo "Skill 已存在: $skill" >&2
  exit 1
fi

"$ROOT/scripts/init-skill" "$skill" "$name" >/dev/null

export SKILLS_REPO_ROOT="$ROOT"
export SKILL_ID="$skill"
export SKILL_NAME="$name"
export SKILL_SUMMARY="$summary"
export SKILL_STYLE="$style"
export SKILL_PLATFORMS="$platforms"

python3 - <<'PY'
from pathlib import Path
import os
import textwrap

root = Path(os.environ['SKILLS_REPO_ROOT'])
skill = os.environ['SKILL_ID']
name = os.environ['SKILL_NAME']
summary = os.environ['SKILL_SUMMARY']
style = os.environ['SKILL_STYLE']
platforms = [p.strip() for p in os.environ['SKILL_PLATFORMS'].split(',') if p.strip()]
dir = root / 'skills' / skill
skill_yaml = dir / 'skill.yaml'
text = skill_yaml.read_text()
text = text.replace('summary: TODO 摘要', f'summary: {summary}')
for platform in ['codex', 'claude', 'cursor']:
    enabled = 'true' if platform in platforms else 'false'
    text = text.replace(f'  {platform}: true', f'  {platform}: {enabled}')
skill_yaml.write_text(text)

files = {
    'intent.md': f'''# 意图\n\n## 一句话说明\n\n{summary}\n\n## 适用场景\n\n- TODO 主要场景\n- TODO 次要场景\n- TODO 目标用户或团队角色\n\n## 默认假设\n\n- TODO 假设 1\n- TODO 假设 2\n- TODO 假设 3\n\n## 典型产出\n\n- TODO 产出 1\n- TODO 产出 2\n- TODO 产出 3\n''',
    'workflow.md': '''# 工作流\n\n## 标准流程\n\n1. TODO 输入理解\n2. TODO 判断与拆解\n3. TODO 执行主流程\n4. TODO 组织输出\n\n## 关键判断点\n\n- TODO 判断规则 1\n- TODO 判断规则 2\n\n## 输出约定\n\n1. TODO 输出顺序 1\n2. TODO 输出顺序 2\n3. TODO 输出顺序 3\n''',
    'prompts.md': '''# Prompt 模板\n\n## 模板 1：基础请求\n\n```text\n请帮我使用这个 skill：\n目标：[一句话]\n输入：[我会提供什么]\n输出：[我希望得到什么]\n约束：[边界或限制]\n```\n\n## 模板 2：把草稿整理成标准结果\n\n```text\n下面是一份 rough draft，请按这个 skill 的工作流整理输出：\n[粘贴内容]\n```\n''',
    'patterns.md': '''# 模式\n\n## 分类方法\n\n- TODO 归纳常见请求类型\n- TODO 定义可复用结构\n\n## 可复用模式\n\n- TODO 模式 1\n- TODO 模式 2\n- TODO 模式 3\n''',
    'style.md': '''# 风格\n\n这个 skill 不依赖视觉风格规则。除非后续证明确实需要视觉输入或设计预设，否则请保持 `style.md` 简洁。\n''' if style == 'no' else '''# 风格\n\n## 视觉输入\n\n- TODO 纯文字风格描述如何转成设计约束\n- TODO 参考产品如何映射成可实现风格\n- TODO 图片风格如何提炼\n\n## 预设\n\n- TODO 预设 1\n- TODO 预设 2\n''',
    'validation.md': '''# 校验\n\n## 最低检查项\n\n- TODO 源文件是否齐全\n- TODO 工作流是否可复用\n- TODO 提示模板是否便于团队成员直接使用\n\n## 校验场景\n\n- 理想输入场景\n- 模糊输入场景\n- 失败或边界场景\n\n## 通过条件\n\n- TODO 条件 1\n- TODO 条件 2\n''',
    'install-notes.md': '''# 安装说明\n\n## 仓库约定\n\n- 编辑 `core/` 和 `skill.yaml`\n- 不要把生成后的 adapters 当作主源\n- 修改后执行 `./scripts/build <skill-id>`\n\n## 平台说明\n\n- Codex adapter 生成在 `adapters/codex/`\n- Claude adapter 生成在 `adapters/claude/`\n- Cursor adapter 生成在 `adapters/cursor/`\n''',
}
for filename, content in files.items():
    (dir / 'core' / filename).write_text(textwrap.dedent(content))

catalog = root / 'catalog.yaml'
entry = textwrap.dedent(f'''\
  - id: {skill}\n    name: {name}\n    version: 0.1.0\n    summary: {summary}\n    platforms:\n      codex: {'true' if 'codex' in platforms else 'false'}\n      claude: {'true' if 'claude' in platforms else 'false'}\n      cursor: {'true' if 'cursor' in platforms else 'false'}\n''')
existing = catalog.read_text()
if f'id: {skill}' not in existing:
    catalog.write_text(existing.rstrip() + '\n' + entry)
PY

"$ROOT/scripts/build" "$skill" >/dev/null
"$ROOT/scripts/doctor" "$skill"

echo "已创建 skill: $skill"
echo "下一步: 使用 cross-tool-skill-creator，把 starter 里的 TODO 块替换成真正可复用的源内容。"
