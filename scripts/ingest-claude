#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

if [ $# -lt 2 ]; then
  echo "Usage: ./scripts/ingest-claude /path/to/CLAUDE.md <skill-id>" >&2
  exit 1
fi

source_file="$1"
skill="$2"
require_skill "$ROOT" "$skill"

if [ ! -f "$source_file" ]; then
  echo "Source CLAUDE.md not found: $source_file" >&2
  exit 1
fi

DIR="$(skill_dir "$ROOT" "$skill")"
stamp="$(date +%Y%m%d_%H%M%S)"
mkdir -p "$DIR/core/imports"
cp "$source_file" "$DIR/core/imports/claude-source-$stamp.md"

echo "ingested $source_file -> $DIR/core/imports/claude-source-$stamp.md"
echo "Next step: manually normalize the imported draft into core/*.md, then run ./scripts/build $skill"
