#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

if [ $# -lt 2 ]; then
  echo "用法: ./scripts/install <codex|claude|cursor> <skill-id> [--project /path/to/project]" >&2
  exit 1
fi

tool="$1"
skill="$2"
shift 2
project=""

while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      project="$2"
      shift 2
      ;;
    *)
      echo "未知参数: $1" >&2
      exit 1
      ;;
  esac
done

require_skill "$ROOT" "$skill"
"$ROOT/scripts/build" "$skill" >/dev/null
SKILL_DIR="$(skill_dir "$ROOT" "$skill")"

case "$tool" in
  codex)
    target="$HOME/.codex/skills/$skill"
    safe_symlink "$SKILL_DIR/adapters/codex" "$target"
    ;;
  claude)
    if [ -z "$project" ]; then
      echo "安装 Claude adapter 时必须提供 --project" >&2
      exit 1
    fi
    safe_symlink "$SKILL_DIR/adapters/claude/CLAUDE.md" "$project/CLAUDE.md"
    ;;
  cursor)
    if [ -z "$project" ]; then
      echo "安装 Cursor adapter 时必须提供 --project" >&2
      exit 1
    fi
    safe_symlink "$SKILL_DIR/adapters/cursor/rules/$skill.mdc" "$project/.cursor/rules/$skill.mdc"
    safe_symlink "$SKILL_DIR/adapters/cursor/AGENTS.md" "$project/AGENTS.md"
    ;;
  *)
    echo "不支持的工具: $tool" >&2
    exit 1
    ;;
esac
