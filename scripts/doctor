#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

if [ $# -lt 1 ]; then
  echo "用法: ./scripts/doctor <skill-id> [--project /path/to/project]" >&2
  exit 1
fi

skill="$1"
shift
project=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      project="$2"
      shift 2
      ;;
    *)
      echo "未知参数: $1" >&2
      exit 1
      ;;
  esac
done

require_skill "$ROOT" "$skill"
DIR="$(skill_dir "$ROOT" "$skill")"

echo "仓库: $ROOT"
echo "skill: $skill"
echo "skill.yaml: $(test -f "$DIR/skill.yaml" && echo 正常 || echo 缺失)"
echo "core 文件:"
for file in intent workflow prompts patterns style validation install-notes; do
  if [ -f "$DIR/core/$file.md" ]; then
    echo "  - $file.md: 正常"
  else
    echo "  - $file.md: 缺失"
  fi
done

echo "adapter 文件:"
for path in \
  "$DIR/adapters/codex/SKILL.md" \
  "$DIR/adapters/codex/agents/openai.yaml" \
  "$DIR/adapters/claude/CLAUDE.md" \
  "$DIR/adapters/cursor/rules/$skill.mdc" \
  "$DIR/adapters/cursor/AGENTS.md"; do
  if [ -e "$path" ]; then
    echo "  - $path: 正常"
  else
    echo "  - $path: 缺失"
  fi
done

if [ -L "$HOME/.codex/skills/$skill" ]; then
  echo "Codex 安装: $(readlink "$HOME/.codex/skills/$skill")"
else
  echo "Codex 安装: 未链接"
fi

if [ -n "$project" ]; then
  if [ -L "$project/CLAUDE.md" ]; then
    echo "Claude 安装: $(readlink "$project/CLAUDE.md")"
  else
    echo "Claude 安装: 未链接"
  fi
  if [ -L "$project/.cursor/rules/$skill.mdc" ]; then
    echo "Cursor 规则安装: $(readlink "$project/.cursor/rules/$skill.mdc")"
  else
    echo "Cursor 规则安装: 未链接"
  fi
  if [ -L "$project/AGENTS.md" ]; then
    echo "Cursor AGENTS 安装: $(readlink "$project/AGENTS.md")"
  else
    echo "Cursor AGENTS 安装: 未链接"
  fi
fi
