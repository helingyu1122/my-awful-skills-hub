#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/lib.sh"
ROOT="$(repo_root)"

if [ $# -lt 1 ]; then
  echo "Usage: ./scripts/doctor <skill-id> [--project /path/to/project]" >&2
  exit 1
fi

skill="$1"
shift
project=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      project="$2"
      shift 2
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

require_skill "$ROOT" "$skill"
DIR="$(skill_dir "$ROOT" "$skill")"

echo "repo: $ROOT"
echo "skill: $skill"
echo "skill.yaml: $(test -f "$DIR/skill.yaml" && echo ok || echo missing)"
echo "core files:"
for file in intent workflow prompts patterns style validation install-notes; do
  if [ -f "$DIR/core/$file.md" ]; then
    echo "  - $file.md: ok"
  else
    echo "  - $file.md: missing"
  fi
done

echo "adapters:"
for path in \
  "$DIR/adapters/codex/SKILL.md" \
  "$DIR/adapters/codex/agents/openai.yaml" \
  "$DIR/adapters/claude/CLAUDE.md" \
  "$DIR/adapters/cursor/rules/$skill.mdc" \
  "$DIR/adapters/cursor/AGENTS.md"; do
  if [ -e "$path" ]; then
    echo "  - $path: ok"
  else
    echo "  - $path: missing"
  fi
done

if [ -L "$HOME/.codex/skills/$skill" ]; then
  echo "codex install: $(readlink "$HOME/.codex/skills/$skill")"
else
  echo "codex install: not linked"
fi

if [ -n "$project" ]; then
  if [ -L "$project/CLAUDE.md" ]; then
    echo "claude install: $(readlink "$project/CLAUDE.md")"
  else
    echo "claude install: not linked"
  fi
  if [ -L "$project/.cursor/rules/$skill.mdc" ]; then
    echo "cursor rule install: $(readlink "$project/.cursor/rules/$skill.mdc")"
  else
    echo "cursor rule install: not linked"
  fi
  if [ -L "$project/AGENTS.md" ]; then
    echo "cursor AGENTS install: $(readlink "$project/AGENTS.md")"
  else
    echo "cursor AGENTS install: not linked"
  fi
fi
